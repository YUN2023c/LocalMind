{
  "name": "LocalMind",
  "productName": "LocalMind",
  "version": "1.0.0",
  "description": "LocalMind - 本地知识库管理系统",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "node src/main/qa-service.test.js && node src/main/fts-fallback.test.js",
    "test:escape": "node src/main/qa-service.test.js",
    "test:fallback": "node src/main/fts-fallback.test.js"
  },
  "keywords": [
    "knowledge",
    "database",
    "local",
    "AI"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "docx": "^9.7.1",
    "electron-store": "^8.1.0",
    "keytar": "^7.9.0",
    "mammoth": "^1.8.0",
    "marked": "^18.0.5",
    "node-llama-cpp": "^3.18.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.0.227",
    "sqlite3": "^5.1.7",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.localmind.app",
    "productName": "LocalMind",
    "directories": {
      "output": "build-output"
    },
    "files": [
      "src/**/*",
      "index.html",
      "preload.js",
      "jsconfig.json",
      "AlimamaAgileVF-Thin.ttf",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "models",
        "to": "models"
      },
      {
        "from": "../logo/ai-logo.ico",
        "to": "app-icon.ico"
      }
    ],
    "win": {
      "icon": "../logo/ai-logo.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
